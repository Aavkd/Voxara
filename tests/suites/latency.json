{
  "name": "Latency Tests",
  "tests": [
    {
      "id": "fast-response",
      "prompt": "Reply with the single word: OK",
      "expect": {
        "keywords": ["OK"],
        "maxLatencyMs": 10000
      }
    },
    {
      "id": "strict-latency",
      "prompt": "What is 1 + 1? Reply with just the number.",
      "expect": {
        "keywords": ["2"],
        "maxLatencyMs": 5000
      }
    }
  ]
}
