# Provider selection: "google" (default), "github", or "ollama"
LLMTEST_PROVIDER=google

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here

# C3a screen vision (captures requested by the user may be sent to this provider)
CONTROL_VISION_PROVIDER=google
CONTROL_SCREENSHOT_MAX_EDGE=1568
CONTROL_JOURNAL_RETENTION_DAYS=30
GOOGLE_MODEL=gemini-2.0-flash

# GitHub Copilot (Models)
GITHUB_TOKEN=your_github_pat_here
GITHUB_MODEL=gpt-4o-mini

# Ollama (local, no API key required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

LLMTEST_LOG_LEVEL=info

# Editable prompt templates
PROMPTS_DIR=./prompts

# Long-term memory directory (defaults to ~/.llmtest/memory)
# LLMTEST_MEMORY_DIR=

# Persistent agent workspace — the stable sandbox where Voxara's file tools
# (and later, delegated coding agents) create and edit files. Defaults to
# ~/.llmtest/workspace. The --sandbox CLI flag overrides it for one session.
# LLMTEST_WORKSPACE_DIR=

# Memory agent (background consolidation) provider/model. Latency-insensitive,
# so a cheaper or local model works well. Defaults to the main provider/model.
# MEMORY_AGENT_PROVIDER=ollama
# MEMORY_AGENT_MODEL=qwen3:8b

# Memory hygiene: episodes older than this many days are compacted into
# quarterly digests (episodes/compacted-<yyyy-qN>.md). Default: 90.
# MEMORY_EPISODE_RETENTION_DAYS=90

# Voice conversation scaffolding
VOICE_LANGUAGE=fr
# STT provider: "faster-whisper" (GPU sidecar, fast) or "whisper-cpp" (CPU CLI fallback)
VOICE_STT_PROVIDER=faster-whisper
# faster-whisper sidecar (npm run stt:start). Model is a CTranslate2 name, not a file.
VOICE_STT_BASE_URL=http://localhost:7862
VOICE_STT_MODEL=large-v3-turbo
VOICE_STT_TIMEOUT_MS=60000
FASTER_WHISPER_DEVICE=cuda
FASTER_WHISPER_COMPUTE=float16
# whisper-cpp fallback (only used when VOICE_STT_PROVIDER=whisper-cpp)
VOICE_STT_BINARY_PATH=whisper-cli
VOICE_STT_MODEL_PATH=./models/whisper/ggml-large-v3-turbo.bin
VOICE_TTS_PROVIDER=piper
PIPER_BINARY_PATH=./tools/piper/bin/piper.exe
PIPER_VOICE=./models/piper/fr_FR-siwis-medium.onnx
# PIPER_SPEAKER=0  # only for the multi-speaker UPMC model
SUPERTONIC_ASSETS_DIR=./models/supertonic
SUPERTONIC_VOICE=F1
# vLLM-Omni Docker serving (npm run tts:vllm) on :8091 — fast (RTF < 1).
# Fallback: pure-Python wrapper (npm run tts:start) on :7861 — ~30s/sentence.
VOICE_TTS_BASE_URL=http://localhost:8091
VOICE_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign
# Per-request TTS timeout (ms). First warm inference of the 1.7B model can take
# tens of seconds; weight download is handled by /health readiness, not this.
VOICE_TTS_TIMEOUT_MS=10000
VOICE_TTS_CHUNK_MIN=40
VOICE_TTS_CHUNK_MAX=260
VOICE_SAMPLE_RATE=16000
VOICE_BARGE_IN=true
VOICE_DEBUG_TRANSCRIPT=true
VOICE_VAD_THRESHOLD=0.018
VOICE_VAD_SPEECH_MS=120
# Trailing silence that ends an utterance. Natural mid-sentence pauses exceed
# 500 ms, which cut sentences in half; 700 is the reasonable floor.
VOICE_VAD_SILENCE_MS=900
# Lower bound for the adaptive VAD threshold. Tune from voice-check calibration
# (suggested = ambient noise peak x 2.5, minimum 0.001).
VOICE_VAD_MIN_THRESHOLD=0.002
# Barge-in (speaking while the assistant answers):
# - VOICE_BARGEIN_THRESHOLD: fixed RMS cutoff from voice-check calibration
#   (suggested = TTS bleed peak x 2). Leave unset for the adaptive monitor.
# VOICE_BARGEIN_THRESHOLD=
# - Continuous speech required to trigger a barge-in (longer than
#   VOICE_VAD_SPEECH_MS so TTS speaker bleed does not self-interrupt).
VOICE_BARGEIN_SPEECH_MS=250

# ── Coding-agent delegation (phase C2) ─────────────────────────────
# Master switch — delegation stays off until enabled explicitly.
DELEGATION_ENABLED=false
# Default backend for backend=auto: auto | codex | claude
DELEGATION_DEFAULT_BACKEND=auto
# Optional explicit executable paths (PATH lookup otherwise)
# CODEX_CLI_PATH=
# CLAUDE_CLI_PATH=
# Comma-separated canonical roots eligible for delegation. Defaults to the
# shared agent workspace (LLMTEST_WORKSPACE_DIR, i.e. ~/.llmtest/workspace).
# DELEGATION_ALLOWED_ROOTS=
# Agent-owned deliverable roots (C2d): write tasks inside these run DIRECTLY
# in place, guarded by automatic Git checkpoints/commits, instead of an
# isolated worktree. Each entry must be inside DELEGATION_ALLOWED_ROOTS
# (violating entries are dropped — see `llmtest delegates doctor`). Defaults
# to the shared agent workspace.
# DELEGATION_AGENT_OWNED_ROOTS=
# Background contextual briefing (C2d-3). Defaults to the memory agent's
# provider/model, which in turn defaults to the main LLM configuration.
# DELEGATION_BRIEF_PROVIDER=
# DELEGATION_BRIEF_MODEL=
# Budgets and retention
DELEGATION_MAX_CONCURRENT=2
DELEGATION_DEFAULT_TIMEOUT_MINUTES=15
DELEGATION_MAX_TIMEOUT_MINUTES=60
DELEGATION_MAX_OUTPUT_BYTES=5242880
DELEGATION_ARTIFACT_RETENTION_DAYS=14
# Comma-separated bare program names allowed for approved external_action
# manifest "execute" steps (e.g. python,node). Empty = no program execution.
# DELEGATION_ALLOWED_PROGRAMS=

# Engine state directory (tasks, delivery queue, delegation artifacts)
# LLMTEST_STATE_DIR=
