{
  "name": "llmtest",
  "version": "0.1.0",
  "description": "LLM API Tester CLI — validate keys, test prompts, chat, and benchmark LLM responses",
  "main": "dist/cli.js",
  "bin": {
    "llmtest": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "npx jest",
    "tts:setup": "powershell -ExecutionPolicy Bypass -File tools/qwen3-tts/setup.ps1",
    "tts:start": "powershell -ExecutionPolicy Bypass -File tools/qwen3-tts/start.ps1",
    "stt:setup": "powershell -ExecutionPolicy Bypass -File tools/faster-whisper/setup.ps1",
    "stt:start": "powershell -ExecutionPolicy Bypass -File tools/faster-whisper/start.ps1",
    "tts:vllm": "powershell -ExecutionPolicy Bypass -File tools/qwen3-tts-vllm/start.ps1",
    "tts:vllm:stop": "docker stop qwen3-tts-vllm",
    "tts:piper:setup": "powershell -ExecutionPolicy Bypass -File tools/piper/setup.ps1",
    "tts:supertonic:setup": "powershell -ExecutionPolicy Bypass -File tools/supertonic/setup.ps1"
  },
  "keywords": [
    "llm",
    "cli",
    "gemini",
    "testing",
    "benchmark"
  ],
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "ajv": "^8.17.1",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "ink": "^3.2.0",
    "onnxruntime-node": "^1.27.0",
    "openai": "^6.37.0",
    "ora": "^5.4.1",
    "react": "^18.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
